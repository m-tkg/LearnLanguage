<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Mac App Store（TestFlight for Mac 含む）配布のため App Sandbox 必須。 -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- 記事取得・Gemini / 画像生成 API・GitHub 等への外向き通信。 -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- iCloud Key-Value Store（設定のデバイス間同期）。 -->
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>

	<!-- SwiftData + CloudKit（記事・画像の同期）。 -->
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.mtkg.LearnLanguage</string>
	</array>

	<!-- CloudKit のサイレントプッシュ。macOS はキー名に com.apple.developer. プレフィックスが付く
	     （iOS の aps-environment と異なる）。 -->
	<key>com.apple.developer.aps-environment</key>
	<string>development</string>
</dict>
</plist>
